rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidService(data) {
      return data.id is string && data.id.size() <= 100 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             data.defaultRate is number && data.defaultRate >= 0 &&
             data.category in ['sqft', 'unit'];
    }

    function isValidBill(data) {
      return data.id is string && data.id.size() <= 100 &&
             data.userId == request.auth.uid &&
             data.customerName is string && data.customerName.size() <= 200 &&
             data.status in ['Pending', 'Paid'] &&
             data.items is list && data.items.size() <= 100 &&
             data.totalAmount is number && data.totalAmount >= 0;
    }

    function isValidExpense(data) {
      return data.id is string && data.id.size() <= 100 &&
             data.userId == request.auth.uid &&
             data.amount is number && data.amount >= 0 &&
             data.description is string && data.description.size() <= 500;
    }

    function isValidPersonal(data) {
      return data.id is string && data.id.size() <= 100 &&
             data.userId == request.auth.uid &&
             data.amount is number && data.amount >= 0 &&
             data.description is string && data.description.size() <= 500;
    }

    function isValidSubscription(data) {
      return data.userId == request.auth.uid &&
             data.installDate is string &&
             data.isActivated is bool;
    }

    // Service Rules
    match /services/{serviceId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidService(incoming()) && isValidId(serviceId);
      allow update: if isOwner(existing().userId) && isValidService(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    // Bill Rules
    match /bills/{billId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidBill(incoming()) && isValidId(billId);
      allow update: if isOwner(existing().userId) && isValidBill(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    // Expense Rules
    match /expenses/{expenseId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidExpense(incoming()) && isValidId(expenseId);
      allow update: if isOwner(existing().userId) && isValidExpense(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    // Personal Transaction Rules
    match /personalTransactions/{transactionId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidPersonal(incoming()) && isValidId(transactionId);
      allow update: if isOwner(existing().userId) && isValidPersonal(incoming()) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }

    // Subscription Rules
    match /subscriptions/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSubscription(incoming());
      allow update: if isOwner(userId) && isValidSubscription(incoming()) && incoming().userId == existing().userId;
    }
  }
}
